{$DOMAIN} {
    # API requests → backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Media files (foto's van inzendingen)
    handle /media/* {
        root * /srv
        file_server
    }

    # Service worker en index.html nooit cachen
    handle /sw.js {
        root * /srv/frontend
        file_server
        header Cache-Control "no-store, no-cache, must-revalidate"
    }

    handle /index.html {
        root * /srv/frontend
        file_server
        header Cache-Control "no-store, no-cache, must-revalidate"
    }

    # Alles anders → React frontend
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    # Compressie
    encode gzip zstd
}
